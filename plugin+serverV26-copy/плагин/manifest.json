{
  "manifest_version": 3,
  "name": "YandexTracker Mobile",
  "version": "1.1.1",
  "description": "Трекер образовательных сайтов с анонимным ID",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YandexTracker"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["browser-polyfill.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
